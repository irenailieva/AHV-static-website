---
import type { Page, GetStaticPaths } from 'astro';

import Layout from '../../layouts/Layout.astro';
import { fetchAnimals } from '../../lib/fetchAnimals.js';

export const getStaticPaths = (async ({ paginate }) => {
    const animals = await fetchAnimals();
    return paginate(animals, { pageSize: 12 });
}) satisfies GetStaticPaths;

interface Props {
    page: Page<{
        name: string;
        description: string;
        imageUrl: string;
        facebookLink: string;
    }>;
}

const { page } = Astro.props;
---

<Layout title="Осинови">
    <!-- Header -->
    <div class="bg-slate-900 py-16 text-white text-center">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
                Осинови приятел
            </h1>
            <p class="text-xl text-slate-300">
                Запознайте се с нашите прекрасни животни, които си търсят дом.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <!-- Animals Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {page.data.map((animal) => (
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col h-full transition-transform hover:-translate-y-1 hover:shadow-md">
                    <div class="aspect-[4/3] w-full bg-slate-100 overflow-hidden relative group">
                        {animal.imageUrl ? (
                            <img 
                                src={animal.imageUrl} 
                                alt={animal.name} 
                                class="w-full h-full object-cover"
                                loading="lazy"
                            />
                        ) : (
                            <img 
                                src="/placeholder.jpg" 
                                alt={animal.name} 
                                class="w-full h-full object-cover"
                                loading="lazy"
                            />
                        )}
                        <div class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/10 transition-colors"></div>
                    </div>
                    <div class="p-6 flex-grow flex flex-col">
                        <div class="flex items-center gap-4 mb-6 pb-4 border-b border-slate-100">
                            <h3 class="text-2xl font-extrabold text-slate-900">{animal.name}</h3>
                        </div>
                        <div class="space-y-3 mb-8">
                            <div class="flex justify-between items-center text-slate-700 bg-slate-50 px-4 py-2 rounded-lg">
                                <span class="font-bold text-sm uppercase tracking-wide">Пол</span>
                                <span class="font-medium">{animal.sex}</span>
                            </div>
                            <div class="flex justify-between items-center text-slate-700 bg-slate-50 px-4 py-2 rounded-lg">
                                <span class="font-bold text-sm uppercase tracking-wide">Година на раждане</span>
                                <span class="font-medium">{animal.birthday}</span>
                            </div>
                        </div>
                    </div>
                    <a href={animal.facebookLink} target="_blank" rel="noopener noreferrer" class="block text-center w-full py-3 px-4 bg-orange-700 text-white font-bold rounded-xl hover:bg-orange-800 transition-colors mt-auto shadow-sm">
                        Вижте във Facebook
                    </a>
                </div>
            ))}
        </div>

        <!-- Pagination Controls -->
        {page.lastPage > 1 && (
            <div class="mt-16 flex items-center justify-center space-x-4">
                {page.url.prev ? (
                    <a 
                        href={page.url.prev} 
                        class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-medium rounded-lg hover:bg-slate-50 hover:text-orange-700 transition-colors"
                    >
                        Предишна
                    </a>
                ) : (
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-600 font-medium rounded-lg cursor-not-allowed">
                        Предишна
                    </span>
                )}

                <div class="flex space-x-2">
                    <span class="px-4 py-2 bg-orange-700 text-white font-bold rounded-lg">
                        {page.currentPage}
                    </span>
                    <span class="px-4 py-2 text-slate-700 font-medium">
                        от {page.lastPage}
                    </span>
                </div>

                {page.url.next ? (
                    <a 
                        href={page.url.next} 
                        class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-medium rounded-lg hover:bg-slate-50 hover:text-orange-700 transition-colors"
                    >
                        Следваща
                    </a>
                ) : (
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-600 font-medium rounded-lg cursor-not-allowed">
                        Следваща
                    </span>
                )}
            </div>
        )}
    </div>
</Layout>
