---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Startseite">
    <!-- Hero Section -->
    <section class="relative bg-orange-50 overflow-hidden">
        <!-- Ghost Dog -->
        <div class="reveal reveal-left delay-300 absolute right-0 md:-right-20 bottom-0 w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] md:w-[600px] md:h-[600px] pointer-events-none">
            <div class="w-full h-full opacity-10 md:opacity-20 mix-blend-multiply bg-no-repeat bg-contain bg-bottom transform-gpu backface-hidden border-transparent" style="background-image: url('/bg-dog.png')"></div>
        </div>
        
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 flex flex-col items-center text-center">
            <h1 class="reveal reveal-up delay-100 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 mb-6">
                Hoffnung schenken für <span class="text-orange-700">obdachlose Tiere</span>
            </h1>
            <p class="reveal reveal-up delay-200 text-lg md:text-xl text-slate-600 max-w-2xl mx-auto mb-10">
                Wir sind eine Nichtregierungsorganisation, die sich der Rettung, Behandlung und Vermittlung von liebevollen Häusern für bedürftige Tiere in Varna, Bulgarien 🇧🇬 und der Region widmet.
            </p>
            <div class="reveal reveal-up delay-300 flex flex-col sm:flex-row gap-4">
                <a href="/de/donate" class="inline-flex justify-center items-center px-8 py-3 border border-transparent text-base font-bold rounded-md text-white bg-orange-700 hover:bg-orange-800 transition-colors shadow-sm">
                    Wie Sie helfen
                </a>
                <a href="/de/volunteer" class="inline-flex justify-center items-center px-8 py-3 border border-slate-300 text-base font-bold rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                    Mehr erfahren
                </a>
            </div>
        </div>
    </section>

    <!-- Impact Section -->
    <section class="relative py-16 bg-white overflow-hidden">
        <!-- Ghost Cat -->
        <div class="reveal reveal-right delay-300 absolute left-0 md:-left-32 bottom-0 w-[250px] h-[250px] sm:w-[350px] sm:h-[350px] md:w-[500px] md:h-[500px] pointer-events-none">
            <div class="w-full h-full opacity-10 md:opacity-20 mix-blend-multiply bg-no-repeat bg-contain bg-bottom transform-gpu backface-hidden border-transparent" style="background-image: url('/bg-cat.png')"></div>
        </div>
        
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold text-slate-900">Was haben wir 2025 erreicht?</h2>
                <p class="mt-4 text-lg text-slate-600">Dank Ihrer Unterstützung verändern wir jeden Tag Leben.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
                <div class="p-6 bg-slate-50 rounded-2xl reveal reveal-up delay-100">
                    <div class="text-4xl font-extrabold text-orange-700 mb-2">119</div>
                    <div class="text-slate-700 font-medium">Gerettete Hunde und Katzen</div>
                </div>
                <div class="p-6 bg-slate-50 rounded-2xl reveal reveal-up delay-200">
                    <div class="text-4xl font-extrabold text-orange-700 mb-2">102</div>
                    <div class="text-slate-700 font-medium">Adoptierte Hunde und Katzen</div>
                </div>
                <div class="p-6 bg-slate-50 rounded-2xl reveal reveal-up delay-300">
                    <div class="text-4xl font-extrabold text-orange-700 mb-2">180</div>
                    <div class="text-slate-700 font-medium">Kastrierte Tiere</div>
                </div>
                <div class="p-6 bg-slate-50 rounded-2xl reveal reveal-up delay-400">
                    <div class="text-4xl font-extrabold text-orange-700 mb-2">150+</div>
                    <div class="text-slate-700 font-medium">Tiere suchen noch ein Zuhause</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Facebook Integration Section -->
    <section class="relative py-16 bg-slate-900 text-white overflow-hidden">
        
        <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="reveal reveal-up delay-100 text-3xl font-bold mb-6">Auf der Suche nach einem neuen Freund?</h2>
            <p class="reveal reveal-up delay-200 text-lg text-slate-300 mb-10">
                Alle unsere Tiere auf der Suche nach einem Zuhause sowie die neuesten Nachrichten über unsere Aktivitäten werden auf unserer offiziellen Facebook-Seite veröffentlicht. Folgen Sie uns, um Teil unserer Gemeinschaft zu werden!
            </p>
            <a href="https://facebook.com/animalhope.varna" target="_blank" rel="noopener noreferrer" class="reveal reveal-up delay-300 inline-flex items-center px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold text-lg transition-colors shadow-lg">
                <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"></path>
                </svg>
                Zur Facebook-Seite
            </a>
        </div>
    </section>
</Layout>
