---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Kontakt">
    <div class="bg-slate-900 py-16 text-white text-center">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="reveal reveal-up delay-100 text-4xl md:text-5xl font-extrabold mb-6">
                Kontaktiere uns
            </h1>
            <p class="reveal reveal-up delay-200 text-xl text-slate-300">
                Haben Sie Fragen oder möchten Sie helfen? Zögern Sie nicht, uns zu
                kontaktieren.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Email -->
            <div
                class="reveal reveal-up delay-100 bg-white p-8 rounded-2xl shadow-sm border border-slate-100 text-center"
            >
                <div
                    class="w-16 h-16 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center mx-auto mb-6"
                >
                    <svg
                        class="w-8 h-8"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">
                    E-Mail
                </h3>
                <p class="text-slate-600 mb-4">
                    Schreiben Sie uns bei allgemeinen Fragen und Partnerschaften.
                </p>
                <span class="inline-flex items-center gap-2">
                    <span class="text-sm sm:text-base lg:text-[13px] xl:text-base font-bold text-orange-700 break-all">animal.hope.varna.bg@gmail.com</span>
                    <button
                        id="copy-email-btn"
                        aria-label="E-Mail-Adresse kopieren"
                        class="relative group flex-shrink-0 cursor-pointer text-slate-400 hover:text-orange-700 transition-colors"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                        <span id="copy-email-tooltip" class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-slate-800 px-2 py-1 text-xs text-white opacity-0 transition-opacity duration-200">Kopiert!</span>
                    </button>
                </span>
            </div>

            <!-- Facebook -->
            <div
                class="reveal reveal-up delay-200 bg-white p-8 rounded-2xl shadow-sm border border-slate-100 text-center"
            >
                <div
                    class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6"
                >
                    <svg
                        class="w-8 h-8"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">Facebook</h3>
                <p class="text-slate-600 mb-4">
                    Alle Adoptionen und neuesten Nachrichten finden hier statt.
                </p>
                <a
                    href="https://facebook.com/animalhope.varna"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
                >
                    Zur Seite gehen
                </a>
            </div>
        </div>

        <!-- Response time notice -->
        <div class="reveal reveal-up delay-300 mt-12 bg-amber-50 border border-amber-200 rounded-2xl p-6 flex gap-4 items-start">
            <svg class="w-6 h-6 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-amber-800 text-sm leading-relaxed">
                <span class="font-bold">Bitte haben Sie Geduld.</span> Die Organisation wird vollständig von Freiwilligen geführt, die ihre Freizeit der Pflege der Tiere widmen. Es ist nicht immer jemand verfügbar, um Ihre Anfrage sofort zu beantworten. Wir werden uns so schnell wie möglich bei Ihnen melden – vielen Dank für Ihr Verständnis!
            </p>
        </div>

        <!-- Contact Form -->
        <div id="contact-form" class="reveal reveal-up delay-400 mt-16 max-w-3xl mx-auto bg-white p-8 sm:p-10 rounded-2xl shadow-sm border border-slate-100">
            <h2 class="text-3xl font-extrabold text-slate-900 mb-8 text-center">Senden Sie uns eine Nachricht</h2>
            <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
                <!-- Access Key from Web3Forms -->
                <input type="hidden" name="access_key" value="8bbbf89c-ba1e-40fe-9fac-fc78a39d7c02">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="name" class="block text-sm font-bold text-slate-700 mb-2">Name</label>
                        <input type="text" name="name" id="name" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50" placeholder="Ihr Name">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-bold text-slate-700 mb-2">E-Mail</label>
                        <input type="email" name="email" id="email" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50" placeholder="ihre@e-mail.com">
                    </div>
                </div>
                
                <div>
                    <label for="subject" class="block text-sm font-bold text-slate-700 mb-2">Betreff</label>
                    <input type="text" name="subject" id="subject" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50" placeholder="Betreff der Nachricht">
                </div>
                
                <div>
                    <label for="message" class="block text-sm font-bold text-slate-700 mb-2">Nachricht</label>
                    <textarea name="message" id="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50 resize-y" placeholder="Wie können wir helfen?"></textarea>
                </div>
                
                <!-- Anti-spam honeypot -->
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
                
                <button type="submit" class="w-full py-4 px-6 text-white text-lg font-bold rounded-xl bg-orange-700 hover:bg-orange-800 transition-colors shadow-sm mt-4">
                    Nachricht senden
                </button>
            </form>
        </div>
    </div>
</Layout>

<script>
    const btn = document.getElementById("copy-email-btn");
    const tooltip = document.getElementById("copy-email-tooltip");
    if (btn && tooltip) {
        btn.addEventListener("click", () => {
            navigator.clipboard.writeText("animal.hope.varna.bg@gmail.com").then(() => {
                tooltip.style.opacity = "1";
                setTimeout(() => { tooltip.style.opacity = "0"; }, 2000);
            });
        });
    }
</script>
