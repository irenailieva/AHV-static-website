---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import catImage from "../../assets/CAT.jpg";
---

<Layout title="Shelter Life">
    <!-- Header -->
    <div class="bg-slate-900 py-16 text-white text-center">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-3xl md:text-5xl font-extrabold mb-6">
                Shelter Life
            </h1>
            <p class="text-lg md:text-xl text-slate-300">
                Learn about our daily routine and find out how you can become part of our volunteer team.
            </p>
        </div>
    </div>

    <!-- Full-width banner -->
    <div class="w-full h-[300px] md:h-[400px] lg:h-[450px] overflow-hidden bg-slate-200 animate-pulse relative banner-container">
        <Image
            src={catImage}
            alt="Volunteer hero banner"
            widths={[640, 1024, 1920]}
            sizes="(max-width: 640px) 640px, (max-width: 1024px) 1024px, 1920px"
            class="w-full h-full object-cover object-center opacity-0 transition-opacity duration-1000 ease-in-out hero-banner-img"
            loading="eager"
            fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/30 to-transparent pointer-events-none"></div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const bannerImg = document.querySelector(".hero-banner-img");
            const container = document.querySelector(".banner-container");
            
            if (bannerImg) {
                const revealImage = () => {
                    requestAnimationFrame(() => {
                        bannerImg.classList.remove("opacity-0");
                        if (container) container.classList.remove("animate-pulse");
                    });
                };

                if (bannerImg.complete) {
                    revealImage();
                } else {
                    bannerImg.addEventListener("load", revealImage);
                }
            }
        });
    </script>

    <!-- Text content section -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 -mt-24 relative z-10 mb-12">
        <div class="bg-white rounded-3xl p-8 md:p-12 shadow-xl border border-slate-100 reveal reveal-up delay-100">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-4xl font-extrabold text-slate-900 mb-6">
                    Our Sunday Meetings
                </h2>
                <p class="text-lg md:text-xl text-slate-600">
                    Every Sunday morning is a special time for us and our four-legged friends. We gather to organize transport, distribute tasks, and head to the shelter.
                </p>
            </div>

            <div class="bg-orange-50 rounded-2xl mb-10 text-center border border-orange-100 overflow-hidden shadow-sm">
                <img 
                    src="/Varna_Cathedral.JPG" 
                    alt="Cathedral of the Assumption, Varna" 
                    class="w-full h-48 sm:h-64 object-cover transition-opacity duration-1000 ease-in-out" 
                    style="opacity: 0;"
                    onload="this.style.opacity = '';"
                />
                <div class="p-8">
                    <h3 class="text-xl md:text-2xl font-bold text-slate-900 mb-4 flex items-center justify-center">
                        <svg class="w-8 h-8 text-orange-700 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Time & Location
                    </h3>
                    <p class="text-xl md:text-2xl font-extrabold text-orange-700 mb-2">
                        Every Sunday at 08:30 AM
                    </p>
                    <p class="text-base md:text-lg text-slate-700">
                        In front of the Cathedral of the Assumption, Varna.
                    </p>
                </div>
            </div>

            <p class="text-base md:text-lg text-slate-600 text-center leading-relaxed">
                If you want to come and help with cleaning, feeding, and caring for the animals, please contact us in advance — write to us on our 
                <a href="https://facebook.com/animalhope.varna" target="_blank" rel="noopener noreferrer" class="text-orange-700 font-bold hover:underline">Facebook page</a>
                or send an email to 
                <a href="mailto:animal.hope.varna.bg@gmail.com" class="text-orange-700 font-bold hover:underline">animal.hope.varna.bg@gmail.com</a>.
                Come in comfortable clothes that you don't mind getting dirty.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">

        <!-- Volunteering Section -->
        <div
            class="bg-slate-50 rounded-3xl p-8 md:p-12 border border-slate-100"
        >
            <div class="text-center mb-12 reveal reveal-up delay-100">
                <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">
                    What does a volunteer do?
                </h2>
                <p class="text-base md:text-lg text-slate-600 max-w-2xl mx-auto">
                    Volunteering with us involves a lot of hard work, but also endless gratitude from the animals.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 reveal reveal-up delay-100"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Socialization
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Many of our animals have been abused or abandoned. The presence of volunteers who care for them with attention and warmth gives them a sense of security — a key step towards their successful adoption.
                    </p>
                </div>
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 reveal reveal-up delay-200"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Care & Hygiene
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Cleaning cages and feeders, changing bedding, and maintaining hygiene in the shelter is a daily and extremely important task for the health of the animals.
                    </p>
                </div>
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 reveal reveal-up delay-300"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Organization
                    </h3>
                    <p class="text-slate-600 text-sm">
                        We help with transportation to veterinary clinics, participating in charity bazaars, and spreading information about animals looking for homes.
                    </p>
                </div>
            </div>
        </div>
    </div>
</Layout>
