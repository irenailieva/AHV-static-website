---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Shelter Life">
    <!-- Header -->
    <div class="bg-slate-900 py-16 text-white text-center">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
                Shelter Life
            </h1>
            <p class="text-xl text-slate-300">
                Learn about our daily routine and find out how you can become part of our volunteer team.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
            <div>
                <h2 class="text-3xl font-bold text-slate-900 mb-6">
                    Our Sunday Meetings
                </h2>
                <div class="prose prose-lg text-slate-600">
                    <p class="mb-4">
                        Every Sunday morning is a special time for us and our four-legged friends. We gather to organize transport, distribute tasks, and head to the shelter.
                    </p>
                    <div
                        class="bg-orange-50 border-l-4 border-orange-500 p-6 rounded-r-lg my-8"
                    >
                        <h3
                            class="text-xl font-bold text-slate-900 mb-2 flex items-center"
                        >
                            <svg
                                class="w-6 h-6 text-orange-700 mr-2"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            Time & Location
                        </h3>
                        <p class="font-medium text-slate-800">
                            Every Sunday at 08:30 AM
                        </p>
                        <p class="text-slate-700">
                            In front of the Cathedral of the Assumption, Varna.
                        </p>
                    </div>
                    <p>
                        If you want to come and help with cleaning, feeding, and caring for the animals, please contact us in advance — write to us on our 
                        <a
                            href="https://facebook.com/animalhope.varna"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-orange-700 font-semibold hover:underline"
                            >Facebook page</a
                        > or send an email to 
                        <a
                            href="mailto:animal.hope.varna.bg@gmail.com"
                            class="text-orange-700 font-semibold hover:underline"
                            >animal.hope.varna.bg@gmail.com</a
                        >. Come in comfortable clothes that you don't mind getting dirty.
                    </p>
                </div>
            </div>
            <div class="rounded-2xl w-full overflow-hidden shadow-lg bg-slate-200 animate-pulse">
                <img
                    src="/svetladimitrova.jpg"
                    alt="Svetla Dimitrova - Head of the organization"
                    class="w-full h-auto object-cover aspect-video opacity-0 transition-opacity duration-700 ease-in-out"
                    onload="this.classList.remove('opacity-0'); this.parentElement.classList.remove('animate-pulse');"
                />
            </div>
        </div>

        <!-- Volunteering Section -->
        <div
            class="bg-slate-50 rounded-3xl p-8 md:p-12 border border-slate-100"
        >
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-slate-900 mb-4">
                    What does a volunteer do?
                </h2>
                <p class="text-lg text-slate-600 max-w-2xl mx-auto">
                    Volunteering with us involves a lot of hard work, but also endless gratitude from the animals.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Socialization
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Many of our animals have been abused or abandoned. The presence of volunteers who care for them with attention and warmth gives them a sense of security — a key step towards their successful adoption.
                    </p>
                </div>
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Care & Hygiene
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Cleaning cages and feeders, changing bedding, and maintaining hygiene in the shelter is a daily and extremely important task for the health of the animals.
                    </p>
                </div>
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Organization
                    </h3>
                    <p class="text-slate-600 text-sm">
                        We help with transportation to veterinary clinics, participating in charity bazaars, and spreading information about animals looking for homes.
                    </p>
                </div>
            </div>
        </div>
    </div>
</Layout>
