---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Contact">
    <div class="bg-slate-900 py-16 text-white text-center">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
                Contact Us
            </h1>
            <p class="text-xl text-slate-300">
                Have questions or want to help? Don't hesitate to reach out.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Email -->
            <div
                class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 text-center"
            >
                <div
                    class="w-16 h-16 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center mx-auto mb-6"
                >
                    <svg
                        class="w-8 h-8"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">
                    Email
                </h3>
                <p class="text-slate-600 mb-4">
                    Write to us for general inquiries and partnerships.
                </p>
                <a
                    href="mailto:animal.hope.varna.bg@gmail.com"
                    class="text-sm sm:text-base lg:text-[13px] xl:text-base font-bold text-orange-700 hover:text-orange-800 transition-colors break-words"
                    >animal.hope.varna.bg@gmail.com</a
                >
            </div>

            <!-- Facebook -->
            <div
                class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 text-center"
            >
                <div
                    class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6"
                >
                    <svg
                        class="w-8 h-8"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">Facebook</h3>
                <p class="text-slate-600 mb-4">
                    All adoptions and latest news happen here.
                </p>
                <a
                    href="https://facebook.com/animalhope.varna"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
                >
                    Go to page
                </a>
            </div>
        </div>

        <!-- Response time notice -->
        <div class="mt-12 bg-amber-50 border border-amber-200 rounded-2xl p-6 flex gap-4 items-start">
            <svg class="w-6 h-6 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-amber-800 text-sm leading-relaxed">
                <span class="font-bold">Please be patient.</span> The organization is run entirely by volunteers who dedicate their free time to caring for the animals. There is not always someone available to respond to your inquiry immediately. We will get back to you as soon as possible — thank you for your understanding!
            </p>
        </div>

        <!-- Contact Form -->
        <div id="contact-form" class="mt-16 max-w-3xl mx-auto bg-white p-8 sm:p-10 rounded-2xl shadow-sm border border-slate-100">
            <h2 class="text-3xl font-extrabold text-slate-900 mb-8 text-center">Send us a message</h2>
            <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
                <!-- ВАЖНО: Заменете '8bbbf89c-ba1e-40fe-9fac-fc78a39d7c02' с вашия Access Key от Web3Forms (web3forms.com) -->
                <input type="hidden" name="access_key" value="8bbbf89c-ba1e-40fe-9fac-fc78a39d7c02">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="name" class="block text-sm font-bold text-slate-700 mb-2">Name</label>
                        <input type="text" name="name" id="name" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50" placeholder="Your name">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-bold text-slate-700 mb-2">Email</label>
                        <input type="email" name="email" id="email" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50" placeholder="your@email.com">
                    </div>
                </div>
                
                <div>
                    <label for="subject" class="block text-sm font-bold text-slate-700 mb-2">Subject</label>
                    <input type="text" name="subject" id="subject" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50" placeholder="Message subject">
                </div>
                
                <div>
                    <label for="message" class="block text-sm font-bold text-slate-700 mb-2">Message</label>
                    <textarea name="message" id="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-700 focus:border-orange-700 outline-none transition-colors bg-slate-50 resize-y" placeholder="How can we help?"></textarea>
                </div>
                
                <!-- Anti-spam honeypot -->
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
                
                <button type="submit" class="w-full py-4 px-6 text-white text-lg font-bold rounded-xl bg-orange-700 hover:bg-orange-800 transition-colors shadow-sm mt-4">
                    Send message
                </button>
            </form>
        </div>
    </div>
</Layout>
