---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import catImage from "../assets/CAT.jpg";
---

<Layout title="Животът в приюта">
    <!-- Header -->
    <div class="bg-slate-900 py-16 text-white text-center">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-3xl md:text-5xl font-extrabold mb-6">
                Животът в приюта
            </h1>
            <p class="text-lg md:text-xl text-slate-300">
                Запознайте се с нашето ежедневие и разберете как можете да
                станете част от нашия екип доброволци.
            </p>
        </div>
    </div>

    <!-- Full-width banner -->
    <div
        class="w-full h-[300px] md:h-[400px] lg:h-[450px] overflow-hidden bg-slate-200 animate-pulse relative banner-container"
    >
        <Image
            src={catImage}
            alt="Доброволци"
            widths={[640, 1024, 1920]}
            sizes="(max-width: 640px) 640px, (max-width: 1024px) 1024px, 1920px"
            class="w-full h-full object-cover object-center opacity-0 transition-opacity duration-1000 ease-in-out hero-banner-img"
            loading="eager"
            fetchpriority="high"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-slate-900/30 to-transparent pointer-events-none"
        >
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const bannerImg = document.querySelector(".hero-banner-img");
            const container = document.querySelector(".banner-container");

            if (bannerImg) {
                const revealImage = () => {
                    requestAnimationFrame(() => {
                        bannerImg.classList.remove("opacity-0");
                        if (container)
                            container.classList.remove("animate-pulse");
                    });
                };

                if (bannerImg.complete) {
                    revealImage();
                } else {
                    bannerImg.addEventListener("load", revealImage);
                }
            }
        });
    </script>

    <!-- Text content section -->
    <div
        class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 -mt-24 relative z-10 mb-12"
    >
        <div
            class="bg-white rounded-3xl p-8 md:p-12 shadow-xl border border-slate-100 reveal reveal-up delay-100"
        >
            <div class="text-center mb-10">
                <h2
                    class="text-2xl md:text-4xl font-extrabold text-slate-900 mb-6"
                >
                    Неделните ни срещи
                </h2>
                <p class="text-lg md:text-xl text-slate-600">
                    Всяка неделя сутрин е специално време за нас и нашите
                    четириноги приятели. Събираме се, за да организираме
                    транспорта, да разпределим задачите и да се отправим към
                    приюта.
                </p>
            </div>

            <div
                class="bg-orange-50 rounded-2xl mb-10 text-center border border-orange-100 overflow-hidden shadow-sm"
            >
                <img src="/Varna_Cathedral.JPG" alt="Катедрален храм „Успение Богородично“, Варна" class="w-full h-48 sm:h-64 object-cover" />
                <div class="p-8">
                    <h3
                        class="text-xl md:text-2xl font-bold text-slate-900 mb-4 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-orange-700 mr-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        Време и място
                    </h3>
                    <p
                        class="text-xl md:text-2xl font-extrabold text-orange-700 mb-2"
                    >
                        Всяка неделя от 08:30 ч.
                    </p>
                    <p class="text-base md:text-lg text-slate-700">
                        Пред Катедралния храм „Успение Богородично“
                        (Катедралата), гр. Варна.
                    </p>
                </div>
            </div>

            <p
                class="text-base md:text-lg text-slate-600 text-center leading-relaxed"
            >
                Ако искате да дойдете и да помогнете с почистването, храненето и
                обгрижването на животните, моля, свържете се с нас предварително
                — пишете ни на
                <a
                    href="https://facebook.com/animalhope.varna"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-orange-700 font-bold hover:underline"
                    >Facebook страницата</a
                >
                или изпратете имейл на
                <a
                    href="mailto:animal.hope.varna.bg@gmail.com"
                    class="text-orange-700 font-bold hover:underline"
                    >animal.hope.varna.bg@gmail.com</a
                >. Елате с удобно облекло, което не ви е жал да изцапате.
            </p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <!-- Volunteering Section -->
        <div
            class="bg-slate-50 rounded-3xl p-8 md:p-12 border border-slate-100"
        >
            <div class="text-center mb-12 reveal reveal-up delay-100">
                <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">
                    Какво прави един доброволец?
                </h2>
                <p
                    class="text-base md:text-lg text-slate-600 max-w-2xl mx-auto"
                >
                    Доброволчеството при нас е свързано с доста работа, но и с
                    безкрайна благодарност от страна на животните.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 reveal reveal-up delay-100"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Социализация
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Много от нашите животни са били малтретирани или
                        изоставени. Присъствието на доброволци, които ги
                        обгрижват с внимание и топлина, им дава чувство за
                        сигурност — ключова стъпка към успешното им осиновяване.
                    </p>
                </div>
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 reveal reveal-up delay-200"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Грижа и хигиена
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Почистването на клетките и хранилките, смяната на
                        постелките и поддържането на хигиената в приюта е
                        ежедневна и изключително важна задача за здравето на
                        животните.
                    </p>
                </div>
                <div
                    class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 reveal reveal-up delay-300"
                >
                    <div
                        class="w-12 h-12 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">
                        Организация
                    </h3>
                    <p class="text-slate-600 text-sm">
                        Помагаме с транспортиране до ветеринарни клиники,
                        участия в благотворителни базари и разпространение на
                        информация за животните, които си търсят дом.
                    </p>
                </div>
            </div>
        </div>
    </div>
</Layout>
