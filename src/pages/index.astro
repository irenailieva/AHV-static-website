---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Начало">
    <!-- Hero Section -->
    <section class="relative bg-orange-50 overflow-hidden">
        <!-- Ghost Dog -->
        <div class="reveal reveal-left delay-300 absolute right-0 md:-right-20 bottom-0 w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] md:w-[600px] md:h-[600px] pointer-events-none">
            <div class="w-full h-full opacity-10 md:opacity-20 mix-blend-multiply bg-no-repeat bg-contain bg-bottom transform-gpu backface-hidden border-transparent" style="background-image: url('/bg-dog.png')"></div>
        </div>
        
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 flex flex-col items-center text-center">
            <h1 class="reveal reveal-up delay-100 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 mb-6">
                Даваме <span class="text-orange-700">надежда</span> на бездомните животни
            </h1>
            <p class="reveal reveal-up delay-200 text-lg md:text-xl text-slate-600 max-w-2xl mx-auto mb-10">
                Ние сме неправителствена организация, посветена на спасяването, лечението и намирането на любящи домове за животни в нужда в град Варна, България 🇧🇬 и региона.
            </p>
            <div class="reveal reveal-up delay-300 flex flex-col sm:flex-row gap-4">
                <a href="/donate" class="inline-flex justify-center items-center px-8 py-3 border border-transparent text-base font-bold rounded-md text-white bg-orange-700 hover:bg-orange-800 transition-colors shadow-sm">
                    Как да помогна
                </a>
                <a href="/adopt" class="inline-flex justify-center items-center px-8 py-3 border border-slate-300 text-base font-bold rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                    Осинови приятел
                </a>
            </div>
        </div>
    </section>

    <!-- About Us & Mission -->
    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="reveal reveal-left delay-100">
                    <h2 class="text-3xl font-extrabold text-slate-900 mb-6">Нашата мисия</h2>
                    <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                        Анимал Хоуп Варна е организация с нестопанска цел, която се стреми да повиши осведомеността срещу жестокостта към животните и да предостави помощ на бездомните животни в град Варна. Ние сме екип от 100% доброволци, обединени от желанието да създадем живот без болка за тези, които нямат глас.
                    </p>
                    <p class="text-lg text-slate-600 leading-relaxed">
                        Не получаваме държавна помощ и се издържаме изцяло от дарения. Всяко спасено животно е доказателство за силата на нашата общност и вашата подкрепа.
                    </p>
                </div>
                <div class="reveal reveal-right delay-200 relative">
                    <div class="aspect-w-16 aspect-h-10 rounded-2xl overflow-hidden shadow-2xl">
                        <img src="https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=1200" alt="Доброволец прегръща спасено куче" class="object-cover w-full h-full" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Activities -->
    <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16 reveal reveal-up">
                <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Какво правим</h2>
                <p class="text-lg text-slate-600">Работим неуморно за осъществяването на нашата мечта чрез комплексна грижа за животните.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Vet Care -->
                <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 reveal reveal-up delay-100 group">
                    <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Ветеринарна помощ</h3>
                    <p class="text-slate-600">Осигуряваме спешно лечение, животоспасяващи процедури и грижа за ранени и болни животни в нашите партньорски клиники.</p>
                </div>
                
                <!-- Preventative Care -->
                <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 reveal reveal-up delay-200 group">
                    <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Превенция</h3>
                    <p class="text-slate-600">Грижим се за чипиране, кастриране, ваксиниране и обезпаразитяване, за да осигурим здрав и сигурен живот.</p>
                </div>
                
                <!-- Fostering -->
                <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 reveal reveal-up delay-300 group">
                    <div class="w-14 h-14 bg-teal-100 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Временни домове</h3>
                    <p class="text-slate-600">Намираме приемни домове за животните, за да могат да се възстановят и социализират в домашна среда.</p>
                </div>

                <!-- Forever Homes -->
                <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 reveal reveal-up delay-400 group">
                    <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Нов живот</h3>
                    <p class="text-slate-600">Вярваме, че всяко животно заслужава шанс и нашата крайна цел е да намерим отговорни стопани и вечен дом.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Adoption Process & International Reach -->
    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col lg:flex-row-reverse gap-12 items-center">
                <div class="lg:w-1/2 reveal reveal-right delay-100">
                    <h2 class="text-3xl font-extrabold text-slate-900 mb-6">Осиновяване и нов дом</h2>
                    <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                        Търсим отговорни осиновители предимно в България, но с помощта на наши доброволци от други страни, животинките ни намират домове също и в Германия, Австрия, Швейцария, Финландия, Холандия, Англия и Италия.
                    </p>
                    <div class="bg-orange-50 border-l-4 border-orange-500 p-6 rounded-r-lg mb-6">
                        <h4 class="text-lg font-bold text-orange-800 mb-2">Нашите изисквания</h4>
                        <p class="text-orange-700">
                            Изискваме от всички потенциални осиновители да попълнят въпросник и да подпишат договор. Така гарантираме най-доброто място за нашите изстрадали бездомничета и предотвратяваме завръщането им на улицата.
                        </p>
                    </div>
                    <p class="text-slate-600 italic text-sm">
                        * Животните ни се дават само за домашни любимци, които ще бъдат третирани като членове на семейството, а не за пазачи на синджир или мишеловки.
                    </p>
                </div>
                <div class="lg:w-1/2 reveal reveal-left delay-200">
                    <div class="grid grid-cols-2 gap-4">
                        <img src="https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&q=80&w=600" alt="Щастливо осиновено куче" class="rounded-2xl shadow-lg object-cover h-48 sm:h-64 w-full transform translate-y-4" />
                        <img src="https://images.unsplash.com/photo-1495360010541-f48722b34f7d?auto=format&fit=crop&q=80&w=600" alt="Спокойна котка в нов дом" class="rounded-2xl shadow-lg object-cover h-48 sm:h-64 w-full transform -translate-y-4" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Section -->
    <section class="relative py-20 bg-slate-900 overflow-hidden text-white">
        <!-- Ghost Cat -->
        <div class="reveal reveal-right delay-300 absolute left-0 md:-left-32 bottom-0 w-[250px] h-[250px] sm:w-[350px] sm:h-[350px] md:w-[500px] md:h-[500px] pointer-events-none opacity-5 z-0">
            <div class="w-full h-full mix-blend-screen bg-no-repeat bg-contain bg-bottom" style="background-image: url('/bg-cat.png')"></div>
        </div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 reveal reveal-up">
                <h2 class="text-3xl font-bold">Какво свършихме през 2025 година?</h2>
                <p class="mt-4 text-lg text-slate-300">Благодарение на вашата подкрепа, ние променяме животи всеки ден.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
                <div class="p-8 bg-slate-800/90 backdrop-blur-md rounded-2xl border border-slate-700 reveal reveal-up delay-100 hover:bg-slate-800 transition-colors shadow-xl">
                    <div class="text-5xl font-extrabold text-orange-500 mb-3">119</div>
                    <div class="text-slate-200 font-medium text-lg">Спасени кучета и котки</div>
                </div>
                <div class="p-8 bg-slate-800/90 backdrop-blur-md rounded-2xl border border-slate-700 reveal reveal-up delay-200 hover:bg-slate-800 transition-colors shadow-xl">
                    <div class="text-5xl font-extrabold text-orange-500 mb-3">102</div>
                    <div class="text-slate-200 font-medium text-lg">Осиновени кучета и котки</div>
                </div>
                <div class="p-8 bg-slate-800/90 backdrop-blur-md rounded-2xl border border-slate-700 reveal reveal-up delay-300 hover:bg-slate-800 transition-colors shadow-xl">
                    <div class="text-5xl font-extrabold text-orange-500 mb-3">180</div>
                    <div class="text-slate-200 font-medium text-lg">Кастрирани животни</div>
                </div>
                <div class="p-8 bg-slate-800/90 backdrop-blur-md rounded-2xl border border-slate-700 reveal reveal-up delay-400 hover:bg-slate-800 transition-colors shadow-xl">
                    <div class="text-5xl font-extrabold text-orange-500 mb-3">150+</div>
                    <div class="text-slate-200 font-medium text-lg">Търсещи своите домове</div>
                </div>
            </div>
        </div>
    </section>

    <!-- How You Can Help -->
    <section class="py-20 bg-orange-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-3xl font-extrabold text-slate-900 mb-6 reveal reveal-up">Всеки може да помогне</h2>
            <p class="text-xl text-slate-600 mb-12 max-w-3xl mx-auto reveal reveal-up delay-100">
                Работата ни е безкрайна, а ние сме малко. Имаме нужда от вашата подкрепа. Не е нужно да живеете в България – имаме доброволци, които ни помагат дистанционно. 
            </p>
            
            <p class="text-lg text-slate-500 mb-6 reveal reveal-up delay-200 font-medium tracking-widest uppercase">Можете да помогнете като:</p>
            <div class="flex flex-wrap justify-center items-center gap-6 md:gap-8 mb-16 reveal reveal-up delay-200">
                <span class="text-2xl md:text-3xl font-extrabold text-orange-700 uppercase tracking-widest">Осиновите</span>
                <span class="hidden md:block text-orange-300 text-2xl">&bull;</span>
                <span class="text-2xl md:text-3xl font-extrabold text-orange-700 uppercase tracking-widest">Приютите</span>
                <span class="hidden md:block text-orange-300 text-2xl">&bull;</span>
                <span class="text-2xl md:text-3xl font-extrabold text-orange-700 uppercase tracking-widest">Дарите</span>
                <span class="hidden md:block text-orange-300 text-2xl">&bull;</span>
                <span class="text-2xl md:text-3xl font-extrabold text-orange-700 uppercase tracking-widest">Споделите</span>
            </div>

            <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-lg text-left reveal reveal-up delay-300">
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Дарителски кутии и клиники</h3>
                <p class="text-slate-600 mb-0">
                    Имаме сключени договори с 8 ветеринарни клиники във Варна за работа при преференциални условия. В тях са поставени дарителски кутии, чрез които всеки може да помогне за лечението на животните.
                </p>
            </div>
        </div>
    </section>

    <!-- Facebook Integration Section -->
    <section class="relative py-16 bg-blue-50 text-slate-900 overflow-hidden">
        <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="reveal reveal-up delay-100 text-3xl font-bold mb-6">Търсите си нов приятел?</h2>
            <p class="reveal reveal-up delay-200 text-lg text-slate-600 mb-10">
                Всички наши животни, които си търсят дом, както и най-актуалните новини за нашата дейност, се публикуват в официалната ни страница във Facebook. Последвайте ни, за да станете част от нашата общност!
            </p>
            <a href="https://facebook.com/animalhope.varna" target="_blank" rel="noopener noreferrer" class="reveal reveal-up delay-300 inline-flex items-center px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold text-lg transition-colors shadow-lg">
                <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"></path>
                </svg>
                Към Facebook страницата
            </a>
        </div>
    </section>
</Layout>
