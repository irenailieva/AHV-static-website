---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Начало">
    <!-- Hero Section -->
    <section class="relative bg-orange-50 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 flex flex-col items-center text-center">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 mb-6">
                Даваме <span class="text-orange-500">надежда</span> на бездомните животни
            </h1>
            <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto mb-10">
                Ние сме неправителствена организация, посветена на спасяването, лечението и намирането на любящи домове за животни в нужда в град Варна и региона.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/donate" class="inline-flex justify-center items-center px-8 py-3 border border-transparent text-base font-bold rounded-md text-white bg-orange-500 hover:bg-orange-600 transition-colors shadow-sm">
                    Как да помогна
                </a>
                <a href="/volunteer" class="inline-flex justify-center items-center px-8 py-3 border border-slate-300 text-base font-bold rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                    Научете повече
                </a>
            </div>
        </div>
    </section>

    <!-- Impact Section -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold text-slate-900">Нашето въздействие</h2>
                <p class="mt-4 text-lg text-slate-600">Благодарение на вашата подкрепа, ние променяме животи всеки ден.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                <div class="p-6 bg-slate-50 rounded-2xl">
                    <div class="text-4xl font-extrabold text-orange-500 mb-2">500+</div>
                    <div class="text-slate-700 font-medium">Спасени животни годишно</div>
                </div>
                <div class="p-6 bg-slate-50 rounded-2xl">
                    <div class="text-4xl font-extrabold text-orange-500 mb-2">300+</div>
                    <div class="text-slate-700 font-medium">Успешни осиновявания</div>
                </div>
                <div class="p-6 bg-slate-50 rounded-2xl">
                    <div class="text-4xl font-extrabold text-orange-500 mb-2">50+</div>
                    <div class="text-slate-700 font-medium">Активни доброволци</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Facebook Integration Section -->
    <section class="py-16 bg-slate-900 text-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-3xl font-bold mb-6">Търсите си нов приятел?</h2>
            <p class="text-lg text-slate-300 mb-10">
                Всички наши животни, които си търсят дом, както и най-актуалните новини за нашата дейност, се публикуват в официалната ни страница във Facebook. Последвайте ни, за да станете част от нашата общност!
            </p>
            <a href="https://facebook.com/animalhope.varna" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold text-lg transition-colors shadow-lg">
                <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"></path>
                </svg>
                Към Facebook страницата
            </a>
        </div>
    </section>
</Layout>
