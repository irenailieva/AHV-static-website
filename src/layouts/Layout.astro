---
import "../styles/global.css";
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
    title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Animal Hope Varna - Официален сайт" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
        <meta name="generator" content={Astro.generator} />
        <link rel="preload" href="/logo_AHV.svg" as="image" type="image/svg+xml" fetchpriority="high" />
        <title>{title} | Animal Hope Varna</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800&family=Bangers&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            @font-face {
                font-family: "Twemoji Country Flags";
                unicode-range: U+1F1E6-1F1FF, U+1F3F4, U+E0062-E0063, U+E0065-E0067, U+E006C, U+E006E, U+E0073-E0074, U+E0077, U+E007F;
                src: url("https://cdn.jsdelivr.net/npm/country-flag-emoji-polyfill@0.1/dist/TwemojiCountryFlags.woff2") format("woff2");
                font-display: swap;
            }

            body {
                font-family: "Twemoji Country Flags", "Montserrat", sans-serif;
                font-weight: 500;
            }
            h1,
            h2,
            h3,
            h4,
            h5,
            h6 {
                font-weight: 800 !important;
            }
        </style>
    </head>
    <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900">
        <header class="bg-white shadow-sm sticky top-0 z-50">
            <nav
                class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center gap-4 sm:gap-8 lg:gap-12"
            >
                <a
                    href={getRelativeLocaleUrl(lang, '/')}
                    class="flex items-center flex-shrink min-w-0"
                >
                    <img
                        src="/logo_AHV.svg"
                        width="425"
                        height="36"
                        class="w-[clamp(170px,25vw,320px)] h-auto object-contain text-transparent"
                        alt="Animal Hope Varna Logo"
                        fetchpriority="high"
                        loading="eager"
                        decoding="sync"
                    />
                </a>

                <!-- Actions Container -->
                <div class="flex items-center">
                    <!-- Desktop Menu Links -->
                    <div class="hidden lg:flex space-x-4 xl:space-x-8 items-center mr-4 lg:mr-8">
                        <a
                            href={getRelativeLocaleUrl(lang, '/')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.home')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/adopt')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.adopt')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/volunteer')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.volunteer')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/donate')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.donate')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/contact')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.contact')}</a
                        >
                    </div>
                    
                    <!-- Language Switcher Dropdown -->
                    <div class="relative group flex items-center">
                        <button id="lang-btn" class="flex items-center gap-1.5 text-slate-600 hover:text-orange-700 font-medium transition-colors p-2 rounded-md focus:outline-none">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span class="uppercase font-bold text-sm">{lang}</span>
                            <svg id="lang-chevron" class="w-4 h-4 text-slate-400 group-hover:text-orange-700 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        
                        <!-- Dropdown Menu -->
                        <div id="lang-dropdown" class="absolute right-0 top-full mt-1 w-36 bg-white rounded-xl shadow-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right scale-95 group-hover:scale-100 z-50 overflow-hidden">
                            <div class="py-1">
                                {Object.entries(languages).map(([code, label]) => {
                                    const isActive = code === lang;
                                    let base = pathname;
                                    if (base.startsWith('/en')) {
                                        base = base.substring(3) || '/';
                                    } else if (base.startsWith('/de')) {
                                        base = base.substring(3) || '/';
                                    }
                                    const href = code === 'bg' ? base : `/${code}${base === '/' ? '' : base}`;
                                    
                                    return (
                                        <a
                                            href={href}
                                            class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
                                                isActive
                                                    ? "bg-orange-50 text-orange-700 font-bold"
                                                    : "text-slate-600 hover:bg-slate-50 hover:text-orange-700"
                                            }`}
                                            title={label}
                                        >
                                            <span class="text-lg leading-none">{code === 'bg' ? '🇧🇬' : code === 'en' ? '🇬🇧' : '🇩🇪'}</span>
                                            <span>{label}</span>
                                        </a>
                                    );
                                })}
                            </div>
                        </div>
                    </div>

                    <!-- Mobile Menu Button -->
                    <button
                        id="menu-btn"
                        class="lg:hidden text-slate-600 hover:text-orange-700 focus:outline-none ml-2 sm:ml-4"
                    >
                        <svg
                            class="h-8 w-8"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                id="menu-icon"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Mobile Menu -->
            <div
                id="mobile-menu"
                class="hidden lg:hidden bg-white border-t border-slate-100 py-4 px-4 space-y-4 shadow-lg absolute w-full left-0"
            >
                <a
                    href={getRelativeLocaleUrl(lang, '/')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.home')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/adopt')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.adopt')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/volunteer')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.volunteer')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/donate')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.donate')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/contact')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.contact')}</a
                >
            </div>
        </header>

        <script>
            const menuBtn = document.getElementById("menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");
            const menuIcon = document.getElementById("menu-icon");

            menuBtn?.addEventListener("click", () => {
                const isHidden = mobileMenu?.classList.toggle("hidden");
                if (!isHidden) {
                    menuIcon?.setAttribute("d", "M6 18L18 6M6 6l12 12");
                } else {
                    menuIcon?.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
                }
            });

            // Language Dropdown Logic (for touch devices & click toggle)
            const langBtn = document.getElementById("lang-btn");
            const langDropdown = document.getElementById("lang-dropdown");
            const langChevron = document.getElementById("lang-chevron");

            langBtn?.addEventListener("click", (e) => {
                e.stopPropagation();
                langDropdown?.classList.toggle("opacity-0");
                langDropdown?.classList.toggle("invisible");
                langDropdown?.classList.toggle("scale-95");
                
                langDropdown?.classList.toggle("opacity-100");
                langDropdown?.classList.toggle("visible");
                langDropdown?.classList.toggle("scale-100");
                
                langChevron?.classList.toggle("rotate-180");
                langChevron?.classList.toggle("text-orange-700");
            });

            document.addEventListener("click", (e) => {
                if (langDropdown && !langBtn?.contains(e.target) && !langDropdown.contains(e.target)) {
                    langDropdown.classList.add("opacity-0", "invisible", "scale-95");
                    langDropdown.classList.remove("opacity-100", "visible", "scale-100");
                    langChevron?.classList.remove("rotate-180", "text-orange-700");
                }
            });

            // Scroll Reveal Logic
            const initScrollReveal = () => {
                const observerOptions = {
                    threshold: 0.1,
                    rootMargin: "0px 0px -50px 0px",
                };

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("reveal-visible");
                            observer.unobserve(entry.target);
                        }
                    });
                }, observerOptions);

                // Automatically target sections in main
                const mainSections = document.querySelectorAll("main section");
                mainSections.forEach((section) => {
                    if (!section.classList.contains("reveal")) {
                        section.classList.add("reveal", "reveal-up");
                    }
                });

                // Observe all elements with reveal class
                const revealElements = document.querySelectorAll(".reveal");
                revealElements.forEach((el) => observer.observe(el));
            };

            // Run on initial load
            initScrollReveal();

            // Run on view transitions if using Astro transitions
            document.addEventListener("astro:after-swap", initScrollReveal);
        </script>

        <main class="flex-grow">
            <slot />
        </main>

        <footer class="bg-slate-900 text-slate-300 py-12 mt-12">
            <div
                class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8"
            >
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">
                        Animal Hope Varna
                    </h3>
                    <p class="text-sm">
                        {t('footer.desc')}
                    </p>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">{t('footer.contacts')}</h3>
                    <ul class="space-y-2 text-sm">
                        <li>
                            <a
                                href={getRelativeLocaleUrl(lang, '/contact#contact-form')}
                                class="hover:text-orange-700 transition-colors"
                                >animal.hope.varna.bg@gmail.com</a>
                        </li>
                        <li>{t('footer.address')}</li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">
                        {t('footer.follow')}
                    </h3>
                    <p class="text-sm mb-4">
                        {t('footer.socialDesc')}
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <a
                            href="https://facebook.com/animalhope.varna"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors"
                        >
                            Facebook
                        </a>
                        <a
                            href="https://www.instagram.com/animal_hope_varna?igsh=MTBvaDM5Y2tvMHAyeQ=="
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded hover:opacity-90 transition-opacity"
                        >
                            Instagram
                        </a>
                        <a
                            href="https://www.tiktok.com/@animal_hope_varna?_r=1&_t=ZN-96NmEDtalk6"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-black text-white rounded hover:bg-zinc-800 transition-colors border border-zinc-700"
                        >
                            TikTok
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
