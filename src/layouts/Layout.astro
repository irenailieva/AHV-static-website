---
import "../styles/global.css";
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
    title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Animal Hope Varna - Официален сайт" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | Animal Hope Varna</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800&family=Bangers&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            body {
                font-family: "Montserrat", sans-serif;
                font-weight: 500;
            }
            h1,
            h2,
            h3,
            h4,
            h5,
            h6 {
                font-weight: 800 !important;
            }
        </style>
    </head>
    <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900">
        <header class="bg-white shadow-sm sticky top-0 z-50">
            <nav
                class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center"
            >
                <a
                    href={getRelativeLocaleUrl(lang, '/')}
                    class="flex items-center gap-2 text-2xl sm:text-3xl text-orange-700 tracking-wide"
                    style="font-family: 'Bangers', cursive; font-weight: 400;"
                >
                    <svg
                        version="1.1"
                        id="svg1"
                        viewBox="0 0 682.66669 682.66669"
                        class="h-8 w-8 object-contain"
                        role="img"
                        aria-label="Animal Hope Varna Logo"
                    >
                        <g id="g1">
                            <g
                                id="g2"
                                transform="matrix(1.7244377,0,0,1.7244377,-307.32173,-190.78082)"
                                style="stroke-width:0.579899;fill:#000000;fill-opacity:1"
                            >
                                <ellipse
                                    style="fill:#000000;stroke:#ffffff;stroke-width:0;stroke-miterlimit:0;fill-opacity:1"
                                    id="path1"
                                    cx="161.27209"
                                    cy="337.70975"
                                    rx="46.799923"
                                    ry="76.899178"
                                    transform="matrix(0.91193029,-0.41034515,0.43266968,0.90155252,0,0)"
                                />
                                <ellipse
                                    style="fill:#000000;stroke:#ffffff;stroke-width:0;stroke-miterlimit:0;fill-opacity:1"
                                    id="path1-8"
                                    cx="374.46262"
                                    cy="224.67854"
                                    rx="46.799923"
                                    ry="76.899178"
                                    transform="matrix(0.9961007,-0.08822361,0.11271776,0.99362705,0,0)"
                                />
                                <path
                                    id="path1-8-1"
                                    style="fill:#000000;stroke:#ffffff;stroke-width:0;stroke-miterlimit:0;fill-opacity:1"
                                    d="m 288.25631,326.95125 c 26.43422,18.09887 36.7958,47.36661 8.64537,76.84198 -18.95873,19.85105 -46.27325,26.04817 -77.19262,-17.59808 -24.95334,-35.22453 -18.29014,-55.28668 -11.64326,-66.92589 7.20828,-12.62229 53.18012,-10.81138 80.19051,7.68199 z"
                                />
                                <path
                                    id="path1-8-1-2"
                                    style="fill:#000000;fill-opacity:1;stroke:#78b7aa;stroke-width:0;stroke-miterlimit:0;stroke-dasharray:none;stroke-opacity:1"
                                    d="m 543.97397,260.0424 c -2.45698,31.94214 -15.61106,57.99537 -55.21269,48.35406 -26.67087,-6.49322 -32.48684,-41.39934 -18.79014,-70.59483 18.33418,-39.08062 34.21975,-40.63888 45.94147,-38.49133 12.09799,2.21649 30.57189,28.09374 28.06136,60.7321 z"
                                />
                                <path
                                    d="m 391.75415,277.40285 c -3.82026,-0.0349 -7.83781,0.40585 -12.0849,1.42039 -25.77814,6.15788 -27.83323,39.55717 -38.99481,83.54845 -3.33099,13.12849 -5.02696,18.17663 -7.99576,25.14017 -5.45234,12.78889 -48.46352,48.88393 -12.82447,93.44087 35.05961,43.83251 73.39309,16.17361 99.14238,-19.65056 7.30764,-10.16689 30.36273,-26.56994 45.02705,-33.12855 33.05359,-14.78318 86.5701,-14.23202 86.32287,-59.80353 -0.24827,-45.76288 -33.8225,-55.43668 -68.48638,-45.82928 -0.0122,0.003 -0.0245,0.007 -0.0367,0.0105 -1.69187,-0.28211 -5.51964,-0.41722 -7.81597,-0.39129 -28.6985,0.32406 -45.32405,-44.41953 -82.25329,-44.75716 z"
                                    style="fill:#000000;stroke:#78b7aa;stroke-width:0;stroke-miterlimit:0;fill-opacity:1"
                                    id="path2"
                                />
                            </g>
                        </g>
                    </svg>
                    <span class="hidden sm:inline">Animal Hope Varna</span>
                    <span class="sm:hidden">Animal Hope</span>
                </a>

                <!-- Actions Container -->
                <div class="flex items-center">
                    <!-- Desktop Menu Links -->
                    <div class="hidden lg:flex space-x-4 xl:space-x-8 items-center mr-4 lg:mr-8">
                        <a
                            href={getRelativeLocaleUrl(lang, '/')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.home')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/adopt')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.adopt')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/volunteer')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.volunteer')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/donate')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.donate')}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(lang, '/contact')}
                            class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                            >{t('nav.contact')}</a
                        >
                    </div>
                    
                    <!-- Language Switchers (Always Visible) -->
                    <div class="flex gap-1 sm:gap-2">
                        {Object.entries(languages).map(([code, label]) => {
                            const isActive = code === lang;
                            let base = pathname;
                            if (base.startsWith('/en')) {
                                base = base.substring(3) || '/';
                            } else if (base.startsWith('/de')) {
                                base = base.substring(3) || '/';
                            }
                            const href = code === 'bg' ? base : `/${code}${base === '/' ? '' : base}`;
                            
                            return (
                                <a
                                    href={href}
                                    class={`flex items-center font-bold border rounded px-1.5 sm:px-2.5 py-1 transition-colors ${
                                        isActive
                                            ? "bg-orange-700 text-white border-orange-700"
                                            : "text-slate-600 border-slate-200 hover:border-orange-700 hover:text-orange-700"
                                    }`}
                                    title={label}
                                >
                                    <span class="text-lg leading-none">{label.split(' ')[0]}</span>
                                    <span class="hidden sm:inline text-sm ml-1">{label.split(' ')[1]}</span>
                                </a>
                            );
                        })}
                    </div>

                    <!-- Mobile Menu Button -->
                    <button
                        id="menu-btn"
                        class="lg:hidden text-slate-600 hover:text-orange-700 focus:outline-none ml-2 sm:ml-4"
                    >
                        <svg
                            class="h-8 w-8"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                id="menu-icon"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Mobile Menu -->
            <div
                id="mobile-menu"
                class="hidden lg:hidden bg-white border-t border-slate-100 py-4 px-4 space-y-4 shadow-lg absolute w-full left-0"
            >
                <a
                    href={getRelativeLocaleUrl(lang, '/')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.home')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/adopt')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.adopt')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/volunteer')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.volunteer')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/donate')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.donate')}</a
                >
                <a
                    href={getRelativeLocaleUrl(lang, '/contact')}
                    class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2"
                    >{t('nav.contact')}</a
                >
            </div>
        </header>

        <script>
            const menuBtn = document.getElementById("menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");
            const menuIcon = document.getElementById("menu-icon");

            menuBtn?.addEventListener("click", () => {
                const isHidden = mobileMenu?.classList.toggle("hidden");
                if (!isHidden) {
                    menuIcon?.setAttribute("d", "M6 18L18 6M6 6l12 12");
                } else {
                    menuIcon?.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
                }
            });

            // Scroll Reveal Logic
            const initScrollReveal = () => {
                const observerOptions = {
                    threshold: 0.1,
                    rootMargin: "0px 0px -50px 0px",
                };

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("reveal-visible");
                            observer.unobserve(entry.target);
                        }
                    });
                }, observerOptions);

                // Automatically target sections in main
                const mainSections = document.querySelectorAll("main section");
                mainSections.forEach((section) => {
                    if (!section.classList.contains("reveal")) {
                        section.classList.add("reveal", "reveal-up");
                    }
                });

                // Observe all elements with reveal class
                const revealElements = document.querySelectorAll(".reveal");
                revealElements.forEach((el) => observer.observe(el));
            };

            // Run on initial load
            initScrollReveal();

            // Run on view transitions if using Astro transitions
            document.addEventListener("astro:after-swap", initScrollReveal);
        </script>

        <main class="flex-grow">
            <slot />
        </main>

        <footer class="bg-slate-900 text-slate-300 py-12 mt-12">
            <div
                class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8"
            >
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">
                        Animal Hope Varna
                    </h3>
                    <p class="text-sm">
                        {t('footer.desc')}
                    </p>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">{t('footer.contacts')}</h3>
                    <ul class="space-y-2 text-sm">
                        <li>
                            <a
                                href={getRelativeLocaleUrl(lang, '/contact#contact-form')}
                                class="hover:text-orange-700 transition-colors"
                                >animal.hope.varna.bg@gmail.com</a>
                        </li>
                        <li>{t('footer.address')}</li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">
                        {t('footer.follow')}
                    </h3>
                    <p class="text-sm mb-4">
                        {t('footer.socialDesc')}
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <a
                            href="https://facebook.com/animalhope.varna"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors"
                        >
                            Facebook
                        </a>
                        <a
                            href="https://www.instagram.com/animal_hope_varna?igsh=MTBvaDM5Y2tvMHAyeQ=="
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded hover:opacity-90 transition-opacity"
                        >
                            Instagram
                        </a>
                        <a
                            href="https://www.tiktok.com/@animal_hope_varna?_r=1&_t=ZN-96NmEDtalk6"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-black text-white rounded hover:bg-zinc-800 transition-colors border border-zinc-700"
                        >
                            TikTok
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
