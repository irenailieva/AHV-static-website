---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="bg">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Animal Hope Varna - Официален сайт" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | Animal Hope Varna</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800&family=Bangers&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            body {
                font-family: "Montserrat", sans-serif;
                font-weight: 500;
            }
            h1,
            h2,
            h3,
            h4,
            h5,
            h6 {
                font-weight: 800 !important;
            }
        </style>
    </head>
    <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900">
        <header class="bg-white shadow-sm sticky top-0 z-50">
            <nav
                class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center"
            >
                <a
                    href="/"
                    class="flex items-center gap-2 text-2xl sm:text-3xl text-orange-700 tracking-wide"
                    style="font-family: 'Bangers', cursive; font-weight: 400;"
                >
                    <img
                        src="/logo-black.png"
                        alt="Animal Hope Varna Logo"
                        class="h-8 w-8 object-contain"
                    />
                    <span class="hidden sm:inline">Animal Hope Varna</span>
                    <span class="sm:hidden">Animal Hope</span>
                </a>
                
                <!-- Desktop Menu -->
                <div class="hidden md:flex space-x-8">
                    <a
                        href="/"
                        class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                        >Начало</a
                    >
                    <a
                        href="/adopt"
                        class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                        >Осинови</a
                    >
                    <a
                        href="/volunteer"
                        class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                        >Доброволци</a
                    >
                    <a
                        href="/donate"
                        class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                        >Дарения</a
                    >
                    <a
                        href="/contact"
                        class="text-slate-600 hover:text-orange-700 font-medium transition-colors"
                        >Контакти</a
                    >
                </div>

                <!-- Mobile Menu Button -->
                <button id="menu-btn" class="md:hidden text-slate-600 hover:text-orange-700 focus:outline-none">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </nav>

            <!-- Mobile Menu -->
            <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 py-4 px-4 space-y-4 shadow-lg absolute w-full left-0">
                <a href="/" class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2">Начало</a>
                <a href="/adopt" class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2">Осинови</a>
                <a href="/volunteer" class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2">Доброволци</a>
                <a href="/donate" class="block text-slate-600 hover:text-orange-700 font-medium transition-colors border-b border-slate-50 pb-2">Дарения</a>
                <a href="/contact" class="block text-slate-600 hover:text-orange-700 font-medium transition-colors">Контакти</a>
            </div>
        </header>

        <script>
            const menuBtn = document.getElementById('menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            const menuIcon = document.getElementById('menu-icon');

            menuBtn?.addEventListener('click', () => {
                const isHidden = mobileMenu?.classList.toggle('hidden');
                if (!isHidden) {
                    menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
                } else {
                    menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
                }
            });

            // Scroll Reveal Logic
            const initScrollReveal = () => {
                const observerOptions = {
                    threshold: 0.1,
                    rootMargin: '0px 0px -50px 0px'
                };

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('reveal-visible');
                            observer.unobserve(entry.target);
                        }
                    });
                }, observerOptions);

                // Automatically target sections in main
                const mainSections = document.querySelectorAll('main section');
                mainSections.forEach(section => {
                    if (!section.classList.contains('reveal')) {
                        section.classList.add('reveal', 'reveal-up');
                    }
                });

                // Observe all elements with reveal class
                const revealElements = document.querySelectorAll('.reveal');
                revealElements.forEach(el => observer.observe(el));
            };

            // Run on initial load
            initScrollReveal();

            // Run on view transitions if using Astro transitions
            document.addEventListener('astro:after-swap', initScrollReveal);
        </script>

        <main class="flex-grow">
            <slot />
        </main>

        <footer class="bg-slate-900 text-slate-300 py-12 mt-12">
            <div
                class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8"
            >
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">
                        Animal Hope Varna
                    </h3>
                    <p class="text-sm">
                        Спасяваме и се грижим за бездомните животни във Варна.
                    </p>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">Контакти</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/contact#contact-form" class="hover:text-orange-700 transition-colors">animal.hope.varna.bg@gmail.com</a></li>
                        <li>Варна, България</li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-4">
                        Последвайте ни
                    </h3>
                    <p class="text-sm mb-4">
                        Всички осиновявания и актуални новини се случват в
                        нашата Facebook страница.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <a
                            href="https://facebook.com/animalhope.varna"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors"
                        >
                            Facebook
                        </a>
                        <a
                            href="https://www.instagram.com/animal_hope_varna?igsh=MTBvaDM5Y2tvMHAyeQ=="
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded hover:opacity-90 transition-opacity"
                        >
                            Instagram
                        </a>
                        <a
                            href="https://www.tiktok.com/@animal_hope_varna?_r=1&_t=ZN-96NmEDtalk6"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-black text-white rounded hover:bg-zinc-800 transition-colors border border-zinc-700"
                        >
                            TikTok
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
